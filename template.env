# =============================================================================
#  Hybrid-Offload Engine + SSCC -- configuration template
#  Copy this file to .env and configure your parameters.
#  (.env is git-ignored, so your API keys never leave your machine.)
# =============================================================================

# -- Local model (Hybrid CPU/GPU offload) -------------------------------------
MODEL_NAME=your_model_file.gguf
GPU_LAYERS=25
CONTEXT_WINDOW=32768

# -- SSCC context compression -------------------------------------------------
SSCC_KEEP_RATIO=0.35        # fraction of chunks to keep (0.35 = best accuracy/saving)
SSCC_ALPHA=0.35             # amplitude weight (information density)
SSCC_GAMMA=0.70             # velocity floor  (recency bias)
SSCC_MIN_KEEP=3             # never keep fewer than N chunks

# -- API mode (SSCC as a paid-API pre-processor; optional) --------------------
# Provider to call AFTER local compression: openai | anthropic
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-20250514

# -- Benchmark toggles (optional) ---------------------------------------------
ENABLE_TOPO_PRUNING=0       # experimental token filter (negative control), keep 0
SHOW_LLAMA_LOGS=0           # 1 = show ALL raw llama.cpp logs
